{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/student",          "destination": "/student.html" },
    { "source": "/login",            "destination": "/login.html" },
    { "source": "/forgot-password",  "destination": "/forgot-password.html" },
    { "source": "/reset-password",   "destination": "/reset-password.html" },
    { "source": "/admin",            "destination": "/admin/dashboard.html" },
    { "source": "/admin/students",   "destination": "/admin/manage-students.html" },
    { "source": "/admin/attendance", "destination": "/admin/attendance.html" },
    { "source": "/admin/register",   "destination": "/admin/register.html" }
  ]
}
